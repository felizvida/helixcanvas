{
  "name": "helixcanvas",
  "version": "0.3.0",
  "private": true,
  "description": "Open-source, local-first biomedical illustration studio for publication-ready figures built from Bioicons, Servier Medical Art, and provenance-aware imports.",
  "keywords": [
    "open-source",
    "open-science",
    "local-first",
    "biomedical",
    "scientific-illustration",
    "bioicons",
    "servier-medical-art",
    "research-figures",
    "react",
    "vite"
  ],
  "homepage": "https://github.com/felizvida/helixcanvas",
  "repository": {
    "type": "git",
    "url": "https://github.com/felizvida/helixcanvas.git"
  },
  "bugs": {
    "url": "https://github.com/felizvida/helixcanvas/issues"
  },
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:api:dev\" \"vite\"",
    "api:dev": "node server/index.mjs",
    "start": "node server/index.mjs",
    "test": "node --test",
    "check:packs": "node scripts/validate-asset-pack.mjs packs",
    "build": "vite build",
    "build:tutorial": "node scripts/generate-tutorial-assets.mjs",
    "preview": "vite preview",
    "build:library": "node scripts/generate-bioicons-index.mjs",
    "check": "npm run check:packs && npm run test && npm run build"
  },
  "dependencies": {
    "concurrently": "^9.2.1",
    "express": "^5.2.1",
    "openai": "^6.34.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "vite": "^7.1.7"
  }
}
